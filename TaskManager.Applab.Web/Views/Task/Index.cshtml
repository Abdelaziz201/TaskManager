@model List<TaskManager.Applab.Web.Models.TaskViewModel>

@{
    ViewData["Title"] = "My Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Task.css" asp-append-version="true" />
}

@{
    var username   = Context.Session.GetString("Username") ?? "there";
    var hour       = DateTime.Now.Hour;
    var greeting   = hour < 12 ? "Good morning" : hour < 18 ? "Good afternoon" : "Good evening";

    var total      = Model.Count;
    var pending    = Model.Count(t => t.Status == "Pending");
    var inProgress = Model.Count(t => t.Status == "InProgress");
    var done       = Model.Count(t => t.Status == "Done");
}

<div class="task-page">

    <div class="task-greeting mb-3">
        <h1>@greeting, @username</h1>
        <p>Here's what you're working on today.</p>
    </div>

    <div class="stat-cards">
        <div class="stat-card active" data-filter="" onclick="filterByStatus(this)">
            <div class="stat-icon purple">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <div><h2 id="statTotal">@total</h2><p>Total</p></div>
        </div>
        <div class="stat-card" data-filter="Pending" onclick="filterByStatus(this)">
            <div class="stat-icon gray">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <path stroke-linecap="round" d="M12 8v4l3 3" />
                </svg>
            </div>
            <div><h2 id="statPending">@pending</h2><p>Pending</p></div>
        </div>
        <div class="stat-card" data-filter="InProgress" onclick="filterByStatus(this)">
            <div class="stat-icon yellow">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <path stroke-linecap="round" d="M12 8v4l3 3" />
                </svg>
            </div>
            <div><h2 id="statInProgress">@inProgress</h2><p>In Progress</p></div>
        </div>
        <div class="stat-card" data-filter="Done" onclick="filterByStatus(this)">
            <div class="stat-icon green">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div><h2 id="statDone">@done</h2><p>Done</p></div>
        </div>
    </div>

    <div class="quick-add-bar">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="quick-add-icon">
            <circle cx="12" cy="12" r="9"/>
        </svg>
        <input type="text" id="quickAddInput" placeholder="Add a task... (press Enter)" />
    </div>

    <div class="task-toolbar">
        <div class="search-wrap">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z" />
            </svg>
            <input type="text" id="searchInput" placeholder="Search tasks..." />
        </div>
        <select id="sortSelect" class="sort-select">
            <option value="">Sort by</option>
            <option value="dueDateAsc">Due Date (Nearest)</option>
            <option value="dueDateDesc">Due Date (Farthest)</option>
        </select>
        <button class="btn-new-task" onclick="openCreateModal()">
            + New Task
        </button>
    </div>

    <div class="task-grid" id="taskGrid">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <p>No tasks yet. Create your first one!</p>
            </div>
        }
        else
        {
            @foreach (var task in Model)
            {
                var badgeClass = task.Status switch
                {
                    "InProgress" => "badge-inprogress",
                    "Done"       => "badge-done",
                    _            => "badge-pending"
                };

                <div class="task-card"
                     data-title="@task.Title.ToLower()"
                     data-id="@task.Id"
                     data-task-title="@task.Title"
                     data-task-description="@task.Description"
                     data-task-duedate="@task.DueDate.ToString("yyyy-MM-ddTHH:mm")"
                     data-task-status="@task.Status">
                    <h3>@task.Title</h3>
                    @if (!string.IsNullOrEmpty(task.Description))
                    {
                        <p>@task.Description</p>
                    }
                    <div class="task-card-footer">
                        <div class="task-card-footer-row">
                            <div class="status-dropdown" data-task-id="@task.Id">
                                <button type="button" class="status-trigger @badgeClass" onclick="toggleStatusMenu(this)">
                                    <span class="status-label">@(task.Status == "InProgress" ? "In Progress" : task.Status)</span>
                                    <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <div class="status-menu">
                                    <div class="status-option badge-pending" data-value="Pending" onclick="selectStatus(this)">Pending</div>
                                    <div class="status-option badge-inprogress" data-value="InProgress" onclick="selectStatus(this)">In Progress</div>
                                    <div class="status-option badge-done" data-value="Done" onclick="selectStatus(this)">Done</div>
                                </div>
                            </div>

                            <div class="task-card-actions">
                                <button class="btn-edit" onclick="openEditModal(this)" title="Edit">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </button>
                                <button class="btn-delete" onclick="deleteTask(@task.Id, this)" title="Delete">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0l-1 14a2 2 0 01-2 2H7a2 2 0 01-2-2L4 6h16z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="task-card-footer-row task-card-meta-row">
                            <span class="task-date">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <rect x="3" y="4" width="18" height="18" rx="2" />
                                    <path d="M16 2v4M8 2v4M3 10h18" />
                                </svg>
                                @task.DueDate.ToString("MMM d, HH:mm")
                            </span>
                            <span class="attachment-badge" title="@task.AttachmentCount attachment(s)">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" />
                                </svg>
                                <span class="attachment-count">@task.AttachmentCount</span>
                            </span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Create / Edit Task Modal -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalTitle">New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="taskId" value="" />
                <div class="mb-3">
                    <label class="form-label fw-500">Title</label>
                    <input type="text" id="taskTitle" class="form-control" placeholder="Task title" />
                    <span id="taskTitleError" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea id="taskDescription" class="form-control" rows="3"
                              placeholder="Optional description"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Due Date</label>
                    <input type="text" id="taskDueDate" class="form-control" placeholder="Select date and time" />
                    <span id="taskDateError" class="text-danger small"></span>
                </div>
                <div class="mb-3" id="attachmentsSection" style="display:none;">
                    <label class="form-label">Attachments</label>
                    <div id="attachmentsList" class="attachments-list"></div>
                    <div class="upload-zone" id="uploadZone">
                        <input type="file" id="fileInput" hidden />
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 0l-3 3m3-3l3 3M3 16.2V18a2 2 0 002 2h14a2 2 0 002-2v-1.8" />
                        </svg>
                        <span>Click to upload a file</span>
                    </div>
                    <div id="uploadError" class="upload-error-box" style="display:none;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="saveTaskBtn" class="btn-new-task">
                    <span id="saveTaskBtnText">Create Task</span>
                    <span id="saveTaskSpinner" class="spinner-border spinner-border-sm ms-1" style="display:none;"></span>
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-4">
                <div class="delete-icon-wrap mb-3">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </div>
                <h5 class="mb-2">Delete this task?</h5>
                <p class="text-muted small mb-4">This action cannot be undone.</p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="confirmDeleteBtn" class="btn-delete-confirm">Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Attachment Confirmation Modal -->
<div class="modal fade" id="deleteAttachmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-4">
                <div class="delete-icon-wrap mb-3">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </div>
                <h5 class="mb-2">Remove this attachment?</h5>
                <p class="text-muted small mb-4">This action cannot be undone.</p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="confirmDeleteAttachmentBtn" class="btn-delete-confirm">Remove</button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Duplicate Title Confirmation Modal -->
<div class="modal fade" id="duplicateConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-4">
                <div class="warning-icon-wrap mb-3">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <h5 class="mb-2">Duplicate task name</h5>
                <p class="text-muted small mb-4" id="duplicateTitleText"></p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="reopenTaskModal()">Cancel</button>
                    <button type="button" id="confirmDuplicateBtn" class="btn-new-task">Create Anyway</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Task/Task.js" asp-append-version="true"></script>
}