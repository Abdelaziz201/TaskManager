@model List<TaskManager.Applab.Web.Models.TaskViewModel>

@{
    ViewData["Title"] = "My Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Task.css" asp-append-version="true" />
}

@{
    var username   = Context.Session.GetString("Username") ?? "there";
    var hour       = DateTime.Now.Hour;
    var greeting   = hour < 12 ? "Good morning" : hour < 18 ? "Good afternoon" : "Good evening";

    var total      = Model.Count;
    var pending    = Model.Count(t => t.Status == "Pending");
    var inProgress = Model.Count(t => t.Status == "InProgress");
    var done       = Model.Count(t => t.Status == "Done");
}

<div class="task-page">

    <!-- Greeting -->
    <div class="task-greeting mb-3">
        <h1>@greeting, @username</h1>
        <p>Here's what you're working on today.</p>
    </div>

    <!-- Stat Cards -->
    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-icon purple">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <div><h2 id="statTotal">@total</h2><p>Total</p></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon gray">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8v4l3 3"/>
                </svg>
            </div>
            <div><h2 id="statPending">@pending</h2><p>Pending</p></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon yellow">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 8v4l3 3"/>
                </svg>
            </div>
            <div><h2 id="statInProgress">@inProgress</h2><p>In Progress</p></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div><h2 id="statDone">@done</h2><p>Done</p></div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="task-toolbar">
        <div class="search-wrap">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z"/>
            </svg>
            <input type="text" id="searchInput" placeholder="Search tasks..." />
        </div>
        <button class="btn-new-task" data-bs-toggle="modal" data-bs-target="#createTaskModal">
            + New Task
        </button>
    </div>

    <!-- Task Grid -->
    <div class="task-grid" id="taskGrid">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <p>No tasks yet. Create your first one!</p>
            </div>
        }
        else
        {
            @foreach (var task in Model)
            {
                var badgeClass = task.Status switch
                {
                    "InProgress" => "badge-inprogress",
                    "Done"       => "badge-done",
                    _            => "badge-pending"
                };

                <div class="task-card" data-title="@task.Title.ToLower()">
                    <h3>@task.Title</h3>
                    @if (!string.IsNullOrEmpty(task.Description))
                    {
                        <p>@task.Description</p>
                    }
                    <div class="task-card-footer">
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            @Html.DropDownList(
                                    $"status-{task.Id}",
                                    new List<SelectListItem>
                                    {
                                        new SelectListItem { Text = "Pending",     Value = "Pending",    Selected = task.Status == "Pending" },
                                        new SelectListItem { Text = "In Progress", Value = "InProgress", Selected = task.Status == "InProgress" },
                                        new SelectListItem { Text = "Done",        Value = "Done",       Selected = task.Status == "Done" }
                                    },
                                    new { @class = "status-select " + badgeClass, data_task_id = task.Id, onchange = "updateStatus(this)" }
                                )
                            <span class="task-date">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                                </svg>
                                @task.DueDate.ToString("MMM d")
                            </span>
                        </div>
                        <div class="task-card-actions">
                            <button class="btn-delete" onclick="deleteTask(@task.Id, this)">Delete</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-500">Title</label>
                    <input type="text" id="taskTitle" class="form-control" placeholder="Task title" />
                    <span id="taskTitleError" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea id="taskDescription" class="form-control" rows="3"
                              placeholder="Optional description"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Due Date</label>
                    <input type="date" id="taskDueDate" class="form-control"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                    <span id="taskDateError" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="createTaskBtn" class="btn-new-task">Create Task</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Task/Task.js" asp-append-version="true"></script>
}