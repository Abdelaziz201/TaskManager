@model TaskManager.Applab.Web.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="account-wrapper">

    <div class="account-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" width="28" height="28">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
    </div>

    <h1 class="account-title">Forgot your password?</h1>
    <p class="account-subtitle">Enter your email and we'll send you a reset link</p>

    <div class="account-card">

        <div id="forgotError" class="text-danger mb-3 small" style="display:none;"></div>
        <div id="forgotSuccess" class="text-success mb-3 small" style="display:none;"></div>

        <div class="mb-4">
            <label class="form-label">Email</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <input type="email" id="forgotEmail" class="form-control" placeholder="you@example.com" />
            </div>
            <span id="forgotEmailError" class="text-danger small"></span>
        </div>

        <button class="btn-account" id="forgotBtn">Send reset link</button>
    </div>

    <p class="account-footer">
        Remembered it? <a asp-controller="Account" asp-action="Login">Back to login</a>
    </p>
</div>

@section Scripts {
    <script src="~/js/Account/ForgotPassword.js" asp-append-version="true"></script>
}