@model TaskManager.Applab.Web.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="account-wrapper">

    <div class="account-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" width="28" height="28">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
    </div>

    <h1 class="account-title">Reset your password</h1>
    <p class="account-subtitle">Choose a new password below</p>

    <div class="account-card">

        <div id="resetError" class="text-danger mb-3 small" style="display:none;"></div>

        <input type="hidden" id="resetToken" value="@Model.Token" />

        <div class="mb-3">
            <label class="form-label">New password</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <input type="password" id="newPassword" class="form-control" placeholder="••••••••" />
            </div>
            <span id="newPasswordError" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label">Confirm new password</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <input type="password" id="confirmPassword" class="form-control" placeholder="••••••••" />
            </div>
            <span id="confirmPasswordError" class="text-danger small"></span>
        </div>

        <button class="btn-account" id="resetBtn">Reset password</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/Account/ResetPassword.js" asp-append-version="true"></script>
}