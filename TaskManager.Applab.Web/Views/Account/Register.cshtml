@model TaskManager.Applab.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="account-wrapper">

    <div class="account-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" width="28" height="28">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
    </div>

    <h1 class="account-title">Create an account</h1>
    <p class="account-subtitle">Start managing your tasks today</p>

    <div class="account-card">

        <div id="registerError" class="text-danger mb-3 small" style="display:none;"></div>

        <!-- Username -->
        <div class="mb-3">
            <label class="form-label">Username</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M5.121 17.804A9 9 0 0112 15a9 9 0 016.879 2.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <input type="text" id="regUsername" class="form-control" placeholder="johndoe" />
            </div>
            <span id="usernameError" class="text-danger small"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <input type="email" id="regEmail" class="form-control" placeholder="you@example.com" />
            </div>
            <span id="regEmailError" class="text-danger small"></span>
        </div>

        <!-- Password -->
        <div class="mb-4">
            <label class="form-label">Password</label>
            <div class="input-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <input type="password" id="regPassword" class="form-control" placeholder="••••••••" />
            </div>
            <span id="regPasswordError" class="text-danger small"></span>
        </div>

        <button class="btn-account" id="registerBtn">Create account</button>
    </div>

    <p class="account-footer">
        Already have an account? <a asp-controller="Account" asp-action="Login">Log in</a>
    </p>
</div>



@section Scripts {
    <script src="~/js/Account/Register.js" asp-append-version="true"></script>
}